graph TD
    %% Define External Actor
    Partner([External Partner / Client App])

    %% Cloud Boundary
    subgraph Cloud[Public Cloud - AWS/Azure VPC]
        WAF[Web Application Firewall<br>Edge Protection & DDoS]
        Apigee[Apigee Edge / Global API Gateway<br>Macro-Policy, Rate Limits & Monetization]
        IdP[[Identity Provider<br>Okta/PingFederate]]

        WAF -->|Sanitized Traffic| Apigee
        Apigee -.->|Token Exchange: External OAuth to Internal JWT| IdP
    end

    %% Network Transit
    Transit((AWS Direct Connect / ExpressRoute<br>Dedicated Private mTLS Link))

    %% On-Premises Boundary
    subgraph OnPrem[On-Premises Physical Data Center]
        F5[Internal Load Balancer<br>F5 BIG-IP / HAProxy]
        
        subgraph PBC[Packaged Business Capability Bounded Context]
            InternalGW[Internal API Gateway<br>Layer 7 or Mule Gateway<br>Micro-Policy & Local Throttling]
            MuleSoft[MuleSoft Runtime<br>Process & System APIs]
        end

        Core[(Legacy Core Banking<br>Mainframe/System of Record)]

        F5 -->|Route to Domain| InternalGW
        InternalGW -->|Validate Internal JWT & Pass Traceparent| MuleSoft
        MuleSoft -->|Transform JSON to SOAP/Copybook| Core
    end

    %% Flow Connections
    Partner -->|mTLS / Public Internet| WAF
    Apigee -->|Pass Internal JWT & W3C Trace Context| Transit
    Transit --> F5

    %% Styling classes to make it visually distinct (Bank/Arch style)
    classDef external fill:#ececff,stroke:#9370db,stroke-width:2px;
    classDef security fill:#ffebee,stroke:#c62828,stroke-width:2px;
    classDef gateway fill:#e0f7fa,stroke:#006064,stroke-width:2px;
    classDef integration fill:#fff3e0,stroke:#ef6c00,stroke-width:2px;
    classDef database fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px;

    class Partner external;
    class WAF security;
    class Apigee,InternalGW gateway;
    class MuleSoft integration;
    class Core database;
